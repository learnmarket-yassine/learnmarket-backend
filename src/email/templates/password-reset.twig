<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8" />
  <title>Reset Your Password</title>
</head>
<body style="font-family: Arial, sans-serif; background: #f4f4f4; padding: 40px;">
  <div style="max-width: 480px; margin: auto; background: #fff; border-radius: 8px; padding: 32px;">

    <h2 style="color: #1a1a1a;">Reset Your Password</h2>

    {% if name %}
      <p>Hi {{ name }},</p>
    {% else %}
      <p>Hi there,</p>
    {% endif %}

    <p>We received a request to reset your password. Use the code below:</p>

    <div style="text-align: center; margin: 32px 0;">
      <span style="font-size: 36px; font-weight: bold; letter-spacing: 8px; color: #4F46E5;">
        {{ otp }}
      </span>
    </div>

    <p style="color: #666;">This code expires in <strong>{{ expiresIn }} minutes</strong>.</p>
    <p style="color: #666;">If you didn't request a password reset, you can safely ignore this email.</p>

    <hr style="border: none; border-top: 1px solid #eee; margin: 24px 0;" />
    <p style="font-size: 12px; color: #999;">LearnMarket — this is an automated email, please do not reply.</p>
  </div>
</body>
</html>